{
  "name": "@jessestricker/extra-projen",
  "description": "More projects and components for projen.",
  "repository": {
    "type": "git",
    "url": "https://github.com/jessestricker/extra-projen.git"
  },
  "scripts": {
    "build": "pnpx projen build",
    "bump": "pnpx projen bump",
    "clobber": "pnpx projen clobber",
    "compile": "pnpx projen compile",
    "default": "pnpx projen default",
    "eject": "pnpx projen eject",
    "eslint": "pnpx projen eslint",
    "package": "pnpx projen package",
    "post-compile": "pnpx projen post-compile",
    "post-upgrade": "pnpx projen post-upgrade",
    "pre-compile": "pnpx projen pre-compile",
    "prettier": "pnpx projen prettier",
    "release": "pnpx projen release",
    "test": "pnpx projen test",
    "test:watch": "pnpx projen test:watch",
    "unbump": "pnpx projen unbump",
    "upgrade": "pnpx projen upgrade",
    "watch": "pnpx projen watch",
    "projen": "pnpx projen"
  },
  "author": {
    "name": "Jesse Stricker",
    "email": "git@jessestricker.de",
    "organization": false
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "commit-and-tag-version": "^12",
    "constructs": "10.0.0",
    "eslint": "^10",
    "jest": "^30.3.0",
    "jest-junit": "^16",
    "prettier": "^3.8.1",
    "projen": "0.98.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8"
  },
  "peerDependencies": {
    "constructs": "^10",
    "projen": ">=0.98.1 <1.0.0"
  },
  "dependencies": {
    "@dprint/formatter": "^0.5.1",
    "@dprint/typescript": "^0.95.15",
    "type-fest": "^5.5.0"
  },
  "pnpm": {},
  "keywords": [
    "projen"
  ],
  "main": "lib/index.js",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.0",
  "jest": {
    "coverageProvider": "v8",
    "testMatch": [
      "<rootDir>/@(src|test)/**/*(*.)@(spec|test).ts?(x)",
      "<rootDir>/@(src|test)/**/__tests__/**/*.ts?(x)",
      "<rootDir>/@(projenrc)/**/*(*.)@(spec|test).ts?(x)",
      "<rootDir>/@(projenrc)/**/__tests__/**/*.ts?(x)"
    ],
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "cobertura",
      "text"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports"
        }
      ]
    ],
    "transform": {
      "^.+\\.[t]sx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.dev.json"
        }
      ]
    }
  },
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js",
    "./typescript": "./lib/typescript/index.js",
    "./javascript": "./lib/javascript/index.js"
  },
  "//": "~~ Generated by projen. To modify, edit .projenrc.ts and run \"pnpx projen\"."
}
